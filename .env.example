# =============================================================================
# ChromePeps Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# ---- Database (PostgreSQL) ----
# For Docker: use "postgres" as host (the service name)
# For local dev: use "localhost"
DATABASE_URL="postgresql://chromepeps:CHANGE_ME_STRONG_PASSWORD@postgres:5432/chromepeps?schema=public"
POSTGRES_PASSWORD="CHANGE_ME_STRONG_PASSWORD"

# ---- Redis ----
# For Docker: use "redis" as host (the service name)
REDIS_URL="redis://redis:6379"

# ---- NextAuth / Auth.js ----
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Google OAuth (Account-Linking via verifizierte Google-Email).
# Anlegen unter https://console.cloud.google.com/apis/credentials —
# Authorized redirect URI: <AUTH_URL>/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ---- hCaptcha (sichtbar nach 2 Login-/Register-Fehlversuchen) ----
# Site-Key + Secret unter https://dashboard.hcaptcha.com erstellen.
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=""
HCAPTCHA_SECRET=""

# ---- Stripe ----
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ---- App ----
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="ChromePeps"

# ---- Email (Resend) ----
# Get your API key at https://resend.com/api-keys
# Verify your sending domain before going live.
RESEND_API_KEY="re_..."
MAIL_FROM="ChromePeps <no-reply@chromepeps.com>"
MAIL_REPLY_TO="support@chromepeps.com"

# ---- COA / Certificates Sync ----
# Public CSV-Export-URL des Google-Sheets, das die Charge-/COA-Daten
# trägt. Wenn nicht gesetzt, fällt der Sync auf den hartkodierten Prod-
# Link in src/app/api/admin/certificates/sync/route.ts zurück.
# COA_SHEET_CSV_URL="https://docs.google.com/spreadsheets/d/<SHEET_ID>/export?format=csv&gid=0"

# ---- Cron Endpoints ----
# Shared-Secret für Cron-Trigger (z.B. /api/cron/review-requests,
# /api/cron/inventory-alerts). Crontab-Aufruf via:
#   curl -fsS -H "Authorization: Bearer $CRON_SECRET" https://chromepeps.com/api/cron/...
# Wenn nicht gesetzt, returnen Cron-Endpoints 503.
CRON_SECRET="generate-with-openssl-rand-base64-32"
