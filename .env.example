# =============================================================================
# ChromePeps Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# ---- Database (PostgreSQL) ----
# For Docker: use "postgres" as host (the service name)
# For local dev: use "localhost"
DATABASE_URL="postgresql://chromepeps:CHANGE_ME_STRONG_PASSWORD@postgres:5432/chromepeps?schema=public"
POSTGRES_PASSWORD="CHANGE_ME_STRONG_PASSWORD"

# ---- Redis ----
# For Docker: use "redis" as host (the service name)
REDIS_URL="redis://redis:6379"

# ---- NextAuth / Auth.js ----
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""

# ---- Stripe ----
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ---- App ----
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="ChromePeps"

# ---- Email (optional, Phase 2) ----
# SMTP_HOST=""
# SMTP_PORT=""
# SMTP_USER=""
# SMTP_PASSWORD=""
# SMTP_FROM="noreply@chromepeps.com"
