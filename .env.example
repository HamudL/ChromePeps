# =============================================================================
# ChromePeps Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# ---- Database (PostgreSQL) ----
# For Docker: use "postgres" as host (the service name)
# For local dev: use "localhost"
DATABASE_URL="postgresql://chromepeps:CHANGE_ME_STRONG_PASSWORD@postgres:5432/chromepeps?schema=public"
POSTGRES_PASSWORD="CHANGE_ME_STRONG_PASSWORD"

# ---- Redis ----
# For Docker: use "redis" as host (the service name)
REDIS_URL="redis://redis:6379"

# ---- NextAuth / Auth.js ----
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Pflicht beim Self-Hosting hinter einem Reverse-Proxy (nginx): NextAuth v5
# lehnt Requests sonst mit "UntrustedHost" ab, weil der Host-Header vom Proxy
# kommt. Wird direkt von der next-auth-Library gelesen (nicht von eigenem
# Code). Lokal ohne Proxy nicht nötig.
AUTH_TRUST_HOST="true"

# Optional: separater, STABILER Schlüssel für die TOTP-Secret-Verschlüsselung
# (AES-256-GCM at rest). Ohne diesen Wert wird der Schlüssel aus AUTH_SECRET
# abgeleitet — das ist der Default und reicht. WICHTIG: Wird dieser Wert (bzw.
# AUTH_SECRET) nach dem Setzen geändert, sind bestehende verschlüsselte
# 2FA-Secrets unlesbar und betroffene User müssen 2FA neu einrichten.
# TOTP_ENC_KEY=""

# Google OAuth (Account-Linking via verifizierte Google-Email).
# Anlegen unter https://console.cloud.google.com/apis/credentials —
# Authorized redirect URI: <AUTH_URL>/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ---- hCaptcha (sichtbar nach 2 Login-/Register-Fehlversuchen) ----
# Site-Key + Secret unter https://dashboard.hcaptcha.com erstellen.
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=""
HCAPTCHA_SECRET=""

# ---- Stripe ----
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ---- App ----
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="ChromePeps"

# ---- Vorkasse / Banküberweisung ----
# Standardmäßig DEAKTIVIERT. Erst aktivieren, wenn eine ECHTE Bankverbindung
# eingetragen ist — die Zahlungsart geht nur live, wenn beides stimmt:
# Flag auf "true" UND IBAN nicht leer (erzwungen in src/lib/constants.ts).
# NEXT_PUBLIC_, weil die Daten im Checkout (Client) angezeigt werden und
# kundensichtbar sind (keine Secrets). Änderung erfordert einen Rebuild.
NEXT_PUBLIC_BANK_TRANSFER_ENABLED="false"
NEXT_PUBLIC_BANK_ACCOUNT_HOLDER=""
NEXT_PUBLIC_BANK_IBAN=""
NEXT_PUBLIC_BANK_BIC=""
NEXT_PUBLIC_BANK_NAME=""

# ---- Verkäufer-/Impressumsdaten ----
# Zentrale Quelle für Impressum, Datenschutz, AGB, Widerruf, Kontakt-Seite
# und das Rechnungs-PDF (src/lib/constants.ts → SELLER_DETAILS).
# Solange diese Werte leer sind, zeigen Impressum & Rechnungen
# "[TODO: …]"-Platzhalter — vor Live-Schaltung zwingend ausfüllen!
# Kein NEXT_PUBLIC_ nötig (nur server-seitig gelesen); Änderungen werden
# erst nach Redeploy/Neustart sichtbar.
SELLER_COMPANY_NAME=""
SELLER_STREET=""
SELLER_POSTAL_CITY=""
SELLER_COUNTRY=""
SELLER_EMAIL=""
SELLER_PHONE=""
SELLER_VAT_ID=""
SELLER_TAX_ID=""
SELLER_REGISTER_COURT=""
SELLER_REGISTER_NUMBER=""
SELLER_MANAGING_DIRECTOR=""

# ---- Email (Resend) ----
# Get your API key at https://resend.com/api-keys
# Verify your sending domain before going live.
RESEND_API_KEY="re_..."
MAIL_FROM="ChromePeps <no-reply@chromepeps.com>"
MAIL_REPLY_TO="support@chromepeps.com"

# ---- COA / Certificates Sync ----
# Public CSV-Export-URL des Google-Sheets, das die Charge-/COA-Daten
# trägt. Wenn nicht gesetzt, fällt der Sync auf den hartkodierten Prod-
# Link in src/app/api/admin/certificates/sync/route.ts zurück.
# COA_SHEET_CSV_URL="https://docs.google.com/spreadsheets/d/<SHEET_ID>/export?format=csv&gid=0"

# ---- Cron Endpoints ----
# Shared-Secret für Cron-Trigger (z.B. /api/cron/review-requests,
# /api/cron/inventory-alerts). Crontab-Aufruf via:
#   curl -fsS -H "Authorization: Bearer $CRON_SECRET" https://chromepeps.com/api/cron/...
# Wenn nicht gesetzt, returnen Cron-Endpoints 503.
CRON_SECRET="generate-with-openssl-rand-base64-32"

# ---- Sentry (Error-Tracking, optional) ----
# Ohne DSN bleibt das SDK ein No-op — alles hier ist optional.
# NEXT_PUBLIC_SENTRY_DSN: Client-DSN, wird zur BUILD-Zeit ins JS-Bundle
#   inlined (im CI-Build als Build-Arg gesetzt, siehe ci-deploy.yml).
# SENTRY_DSN: Server-/Edge-Fallback zur Laufzeit
#   (src/sentry.server.config.ts, src/sentry.edge.config.ts).
# SENTRY_AUTH_TOKEN/ORG/PROJECT: nur zur Build-Zeit für den Source-Map-
#   Upload (next.config.ts → withSentryConfig); landen nicht im Image.
# NEXT_PUBLIC_SENTRY_DSN=""
# SENTRY_DSN=""
# SENTRY_AUTH_TOKEN=""
# SENTRY_ORG=""
# SENTRY_PROJECT=""

# ---- Plausible Analytics (self-hosted, optional) ----
# Wird NICHT vom App-Code gelesen, sondern von docker/docker-compose.yml
# (Profil "analytics"): docker compose --profile analytics up -d.
# Das Tracking-Script in src/app/layout.tsx ist fest auf
# analytics.chromepeps.com verdrahtet.
# PLAUSIBLE_BASE_URL="https://analytics.chromepeps.com"
# Generieren mit: openssl rand -base64 48
# PLAUSIBLE_SECRET_KEY_BASE=""
# Default "invite_only" — Registrierung nur per Einladung.
# PLAUSIBLE_DISABLE_REGISTRATION="invite_only"
