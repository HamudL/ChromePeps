generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// AUTH & USER
// ============================================================

enum Role {
  USER
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  passwordHash  String?
  role          Role      @default(USER)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // === 2FA / TOTP ============================================
  // `totpSecret` hält den Base32-kodierten Secret-Wert (otplib).
  // Nicht verschlüsselt at-rest — die DB ist die Trust-Boundary,
  // wer DB-Zugriff hat kann eh alle Sessions beenden / Passwörter
  // resetten. Encryption-at-rest wäre Defense-in-Depth, aber für
  // Soft-2FA bewusst ausgespart (KISS).
  // `totpEnabledAt` ist null solange 2FA nicht aktiv ist. Sobald
  // der User die erste TOTP-Code-Bestätigung im Setup-Flow
  // erfolgreich liefert, wird der Timestamp gesetzt.
  // `totpRecoveryCodes` ist ein Array von bcrypt-Hashes der
  // 10 Recovery-Codes, die einmalig im Setup angezeigt werden.
  // Bei Verbrauch wird der jeweilige Hash aus dem Array entfernt.
  // Wenn alle aufgebraucht: User muss neu generieren.
  // AUDIT_REPORT_v3 §4.2 + §6 PR 7.
  totpSecret        String?
  totpEnabledAt     DateTime?
  totpRecoveryCodes String[]  @default([])

  accounts      Account[]
  sessions      Session[]
  orders        Order[]
  cart          Cart?
  reviews       Review[]
  addresses     Address[]
  promoUsages   PromoUsage[]
  wishlistItems WishlistItem[]

  // KEIN @@index([email]) — `email @unique` legt bereits einen B-Tree-
  // Index an, ein zweiter wäre 100 % deckungsgleich.
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  // SHA-256 hash of the raw token sent by email. Never store the raw token.
  tokenHash String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

// ============================================================
// PRODUCT CATALOG
// ============================================================

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?  @db.Text
  image       String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]

  // KEIN @@index([slug]) — slug ist bereits @unique.
  @@map("categories")
}

model Product {
  id                    String   @id @default(cuid())
  name                  String
  slug                  String   @unique
  description           String   @db.Text
  shortDesc             String?  @db.VarChar(300)
  sku                   String   @unique
  priceInCents          Int
  compareAtPriceInCents Int?
  categoryId            String
  stock                 Int      @default(0)
  isActive              Boolean  @default(true)
  isBestseller          Boolean  @default(false)
  // Manuelle Sortierreihenfolge in Listings. Niedriger = weiter vorn.
  // Wird im Admin per Drag-and-Drop gesetzt, fällt sonst auf den
  // sekundären Sort (createdAt desc) zurück.
  sortOrder             Int      @default(0)
  purity                String?  @db.VarChar(20)
  molecularWeight       String?  @db.VarChar(50)
  sequence              String?  @db.Text
  casNumber             String?  @db.VarChar(30)
  storageTemp           String?  @db.VarChar(50)
  form                  String?  @db.VarChar(50)
  weight                String?  @db.VarChar(50)
  // Pro-Produkt-Schwelle für Low-Stock-Alerts (Cron + Admin-Banner).
  // Default 5 entspricht der vorherigen globalen LOW_STOCK_THRESHOLD-
  // Konstante. Pro Produkt überschreibbar — bei spezialisierten Items
  // sinnvoll niedriger (2-3), bei Hot-Sellern höher (10+).
  // AUDIT_REPORT_v3 §4.8.
  lowStockThreshold     Int      @default(5)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  category      Category                @relation(fields: [categoryId], references: [id])
  images        ProductImage[]
  cartItems     CartItem[]
  orderItems    OrderItem[]
  reviews       Review[]
  variants      ProductVariant[]
  wishlistItems WishlistItem[]
  certificates  CertificateOfAnalysis[]

  // Wenn dieses Produkt ein Blend ist, listet `components` die Wirkstoffe
  // (jeweils selbst eigenständige Produkte mit eigenen COAs). Wenn dieses
  // Produkt selbst Wirkstoff in einem Blend ist, taucht es in
  // `usedInBlends` der Blend-Eltern auf.
  components   ProductComponent[] @relation("BlendParent")
  usedInBlends ProductComponent[] @relation("BlendComponent")

  // KEIN @@index([slug]) — slug ist bereits @unique.
  @@index([categoryId])
  @@index([isActive, categoryId])
  @@index([sortOrder])
  // Compound-Indices für Hot-Path-Listings.
  // Hauptkatalog: WHERE isActive=true [+ optional weitere Filter]
  //               ORDER BY sortOrder ASC, createdAt DESC LIMIT 12
  // → Postgres kann den vollständigen Sort aus dem Index lesen, ohne
  //   Filter→Sort-Materialisierung. Bei 1k+ Produkten messbar.
  @@index([isActive, sortOrder, createdAt(sort: Desc)])
  // Kategorie-Listing: WHERE isActive=true AND categoryId=?
  //                    ORDER BY sortOrder ASC, createdAt DESC
  // → wie oben, aber pro Kategorie. Macht den vorhandenen
  //   (isActive, categoryId)-Index nicht obsolet (FK-Joins ohne
  //   sortOrder), aber für die typische Customer-Reihenfolge
  //   schneller.
  @@index([isActive, categoryId, sortOrder])
  @@map("products")
}

// Versandkosten pro Land. Wird pro Bestellung anhand der Lieferadresse
// resolved. Free-Shipping-Schwelle gilt EU-weit über
// `FREE_SHIPPING_THRESHOLD_CENTS` in lib/order/calculate-totals.
model ShippingRate {
  id           String   @id @default(cuid())
  countryCode  String   @unique @db.VarChar(2)
  countryName  String   @db.VarChar(80)
  priceInCents Int
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isActive])
  @@map("shipping_rates")
}

model ProductImage {
  id        String  @id @default(cuid())
  url       String
  alt       String?
  sortOrder Int     @default(0)
  productId String

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model ProductVariant {
  id           String  @id @default(cuid())
  productId    String
  name         String
  sku          String  @unique
  priceInCents Int
  stock        Int     @default(0)
  isActive     Boolean @default(true)

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@index([productId])
  @@map("product_variants")
}

// ============================================================
// CART
// ============================================================

model Cart {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@map("carts")
}

model CartItem {
  id        String  @id @default(cuid())
  cartId    String
  productId String
  variantId String?
  quantity  Int     @default(1)

  cart    Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId, variantId])
  @@map("cart_items")
}

// ============================================================
// ORDERS & PAYMENTS
// ============================================================

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
  ARCHIVED
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

model Order {
  id                    String        @id @default(cuid())
  orderNumber           String        @unique
  // userId is now NULLABLE to support guest checkout. Exactly one of
  // (userId, guestEmail) must be set — enforced at the application
  // layer, not the DB, because Postgres/Prisma can't express an
  // "either-or non-null" constraint cleanly without a CHECK clause.
  userId                String?
  // guestEmail/guestName populate ONLY for orders placed without an
  // account. For authenticated orders these stay null and the
  // address/email come from the linked User row.
  guestEmail            String?
  guestName             String?
  status                OrderStatus   @default(PENDING)
  paymentStatus         PaymentStatus @default(PENDING)
  paymentMethod         String        @default("STRIPE") @db.VarChar(20)
  stripePaymentIntentId String?       @unique
  stripeSessionId       String?       @unique
  subtotalInCents       Int
  shippingInCents       Int           @default(0)
  taxInCents            Int           @default(0)
  totalInCents          Int
  currency              String        @default("eur") @db.VarChar(3)
  shippingAddressId     String?
  billingAddressId      String?
  notes                 String?       @db.Text
  trackingNumber        String?
  shippedAt             DateTime?
  deliveredAt           DateTime?
  cancelledAt           DateTime?
  // Wird gesetzt, sobald die Review-Request-Mail an den Kunden ging
  // (entweder beim Status-Wechsel auf DELIVERED via Admin-UI, oder
  // verzögert via /api/cron/review-requests). Idempotenz-Schutz
  // gegen Doppel-Mails. Siehe AUDIT_REPORT_v3 §3.2.
  reviewRequestedAt     DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  discountInCents Int     @default(0)
  promoCode       String? @db.VarChar(20)

  // Admin-only Flag: markiert fiktive Orders, die Dashboards, Statistiken,
  // Exports und Email-Versand NICHT beeinflussen sollen. Pattern analog zu
  // status=ARCHIVED — überall wo Orders gezählt werden, wird
  // { isTestOrder: false } gefiltert.
  isTestOrder Boolean @default(false)

  user            User?        @relation(fields: [userId], references: [id])
  items           OrderItem[]
  shippingAddress Address?     @relation("ShippingAddress", fields: [shippingAddressId], references: [id])
  billingAddress  Address?     @relation("BillingAddress", fields: [billingAddressId], references: [id])
  events          OrderEvent[]
  promoUsage      PromoUsage?
  invoice         Invoice?

  @@index([userId])
  // Guest-order lookup by email (public order-status page). Compound
  // with orderNumber for the auth check.
  @@index([guestEmail])
  @@index([status])
  // KEIN @@index([orderNumber]) / @@index([stripePaymentIntentId]) —
  // beide sind bereits @unique (s.o.), der explizite Single-Index wäre
  // ein doppelter B-Tree.
  // KEIN @@index([isTestOrder]) — durch das Compound-Index unten
  // (isTestOrder, createdAt DESC) abgedeckt. Postgres würde einen
  // Boolean-Singleton-Index ohnehin bei niedriger Selektivität
  // selten direkt nutzen.
  // Compound-Index für Admin-Order-Liste:
  //   WHERE isTestOrder=false [+ optional status]
  //   ORDER BY createdAt DESC LIMIT 20
  // → ersetzt heute zwei separate Index-Scans + Sort. Bei 10k+ Orders
  //   spürbar (~50-200 ms).
  @@index([isTestOrder, createdAt(sort: Desc)])
  // Compound-Index für Dashboard-Order-Liste:
  //   WHERE userId=? ORDER BY createdAt DESC
  // → User mit vielen Bestellungen sehen die neueste sofort, ohne
  //   Postgres muss das gesamte User-Order-Set sortieren.
  @@index([userId, createdAt(sort: Desc)])
  @@map("orders")
}

// ============================================================
// INVOICES (UStG §14 compliant — fortlaufende, lueckenlose Nummerierung)
// ============================================================
//
// One invoice per order. invoiceNumber is the canonical human-readable
// identifier (e.g. "CP-RE-2026-0001"). The (year, seq) composite unique
// guarantees gapless numbering per calendar year when allocated inside a
// transaction. issuedAt freezes the legal issue date.
model Invoice {
  id            String   @id @default(cuid())
  invoiceNumber String   @unique
  orderId       String   @unique
  year          Int
  seq           Int
  issuedAt      DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([year, seq])
  @@index([year])
  @@map("invoices")
}

model OrderItem {
  id           String  @id @default(cuid())
  orderId      String
  productId    String?
  variantId    String?
  productName  String
  variantName  String?
  sku          String
  quantity     Int
  priceInCents Int

  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@map("order_items")
}

model OrderEvent {
  id        String      @id @default(cuid())
  orderId   String
  status    OrderStatus
  note      String?     @db.Text
  createdAt DateTime    @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_events")
}

// ============================================================
// ADDRESS
// ============================================================

model Address {
  id         String  @id @default(cuid())
  // Nullable to support guest-order addresses. Guest addresses are
  // created inline at checkout, attached to the Order via
  // shippingAddressId, and never show up in any user's "my
  // addresses" list. They persist as rows so historical orders can
  // still resolve to their shipping info, and cleanup (if wanted)
  // can be done with a soft retention job.
  userId     String?
  label      String? @db.VarChar(50)
  company    String?
  firstName  String
  lastName   String
  street     String
  street2    String?
  city       String
  state      String?
  postalCode String
  country    String  @db.VarChar(2)
  phone      String?
  isDefault  Boolean @default(false)

  user           User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  shippingOrders Order[] @relation("ShippingAddress")
  billingOrders  Order[] @relation("BillingAddress")

  @@index([userId])
  @@map("addresses")
}

// ============================================================
// REVIEWS
// ============================================================

model Review {
  id         String   @id @default(cuid())
  userId     String
  productId  String
  rating     Int      @db.SmallInt
  title      String?
  body       String?  @db.Text
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId])
  @@map("reviews")
}

// ============================================================
// PROMO CODES
// ============================================================

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

model PromoCode {
  id             String       @id @default(cuid())
  code           String       @unique
  description    String?      @db.Text
  discountType   DiscountType
  discountValue  Int // percentage (1-100) or cents
  maxUses        Int? // null = unlimited
  usedCount      Int          @default(0)
  minOrderCents  Int? // minimum order subtotal in cents
  isActive       Boolean      @default(true)
  isCombinable   Boolean      @default(false)
  startsAt       DateTime?
  expiresAt      DateTime?
  // Stripe Coupon ID cache. We used to create a new Stripe coupon on every
  // checkout that applied this promo — 100 checkouts meant 100 Stripe API
  // calls + 100 dashboard entries, all describing the same discount. Now
  // the first checkout creates the coupon and persists its ID; later
  // checkouts reuse it. Nullable so the migration stays backwards-
  // compatible (old code reading the record just sees `undefined`).
  stripeCouponId String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  usages PromoUsage[]

  // KEIN @@index([code]) — code ist bereits @unique.
  @@index([isActive, expiresAt])
  @@map("promo_codes")
}

model PromoUsage {
  id             String   @id @default(cuid())
  promoId        String
  // userId is nullable so guest checkouts can redeem promo codes.
  // For guest redemptions, guestEmail carries the "already used this
  // code?" check instead. Exactly one of (userId, guestEmail) must
  // be set per row — enforced at the application layer.
  userId         String?
  guestEmail     String?
  orderId        String   @unique
  discountAmount Int // actual discount applied in cents
  createdAt      DateTime @default(now())

  promo PromoCode @relation(fields: [promoId], references: [id], onDelete: Cascade)
  user  User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  order Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([promoId])
  @@index([userId])
  // Guest "once per email per promo" check lookup.
  @@index([promoId, guestEmail])
  @@map("promo_usages")
}

// ============================================================
// STRIPE WEBHOOK IDEMPOTENCY
// ============================================================

model StripeEvent {
  id              String   @id
  type            String
  processedAt     DateTime @default(now())
  payloadSnapshot Json?

  @@map("stripe_events")
}

// ============================================================
// NEWSLETTER
// ============================================================

model NewsletterSubscriber {
  id          String    @id @default(cuid())
  email       String    @unique
  token       String    @unique @default(cuid())
  confirmedAt DateTime?
  createdAt   DateTime  @default(now())

  // KEIN @@index([email]) / @@index([token]) — beide bereits @unique.
  @@map("newsletter_subscribers")
}

// ============================================================
// WISHLIST
// ============================================================

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@map("wishlist_items")
}

// ============================================================
// CERTIFICATES OF ANALYSIS (COA)
// ============================================================

model CertificateOfAnalysis {
  id          String   @id @default(cuid())
  productId   String
  batchNumber String
  testDate    DateTime
  purity      Float?
  testMethod  String   @default("HPLC")
  laboratory  String   @default("Janoshik")
  // Optionale Dosis-Angabe pro COA (z.B. "5mg", "10mg"). Bei Produkten
  // mit Varianten matcht die Mail-Logik OrderItem.variantName gegen
  // diesen Wert, damit ein 5-mg-Kunde den 5-mg-COA bekommt und nicht
  // den 10-mg-COA derselben Charge. Free-form String, weil die genaue
  // Notation pro Produkt schwankt ("5mg" / "5 mg" / "5mg/Vial").
  dosage      String?  @db.VarChar(20)
  reportUrl   String?
  pdfUrl      String?
  notes       String?  @db.Text
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  // Hot-Path-Sub-Query in productCardSelect:
  //   WHERE productId=? AND isPublished=true
  //   ORDER BY testDate DESC LIMIT 1
  // → wird pro ProductCard 1x ausgeführt. Bei 12 Cards/Listing
  //   sind das 12 Sub-Queries. Mit diesem Compound liest Postgres
  //   den nötigen Datensatz direkt aus dem Index, ohne weitere
  //   Filter+Sort-Phase.
  @@index([productId, isPublished, testDate(sort: Desc)])
  @@map("certificates_of_analysis")
}

// Blend-Komponenten: ein Blend-Produkt (parent) verweist auf seine
// Wirkstoff-Bestandteile (component), die selbst Produkte mit eigenen
// COAs sind. Bei einer Bestellung des Blends sollen die COAs der
// Komponenten in der Bestätigungs-Mail mitgeschickt werden — siehe
// loadCoaAttachments. Kein dosage-Feld hier, weil die Komponente selbst
// als eigenes Produkt mit Varianten/COAs existiert; die passende Dosis
// kommt aus dem Blend-Naming bzw. dem Komponenten-COA-Match (Fallback
// auf neuesten COA, wenn keine spezifische Dosis sich übersetzen lässt).
model ProductComponent {
  id                 String @id @default(cuid())
  parentProductId    String
  componentProductId String
  sortOrder          Int    @default(0)

  parent    Product @relation("BlendParent", fields: [parentProductId], references: [id], onDelete: Cascade)
  // Cascade auch auf component: wird ein Komponenten-Produkt (z.B. RG3)
  // gelöscht, wird dieser ProductComponent-Eintrag mitgelöscht — der
  // Blend selbst bleibt erhalten, hat dann nur eine Komponente weniger.
  // Vorher (RESTRICT): Delete des Komponenten-Produkts wurde mit
  // FK-Error blockiert, Admin musste die Blend-Beziehung manuell lösen.
  component Product @relation("BlendComponent", fields: [componentProductId], references: [id], onDelete: Cascade)

  // Ein Blend listet eine Komponente nur einmal — Dosen-Variation passiert
  // über die Komponenten-COAs.
  @@unique([parentProductId, componentProductId])
  @@index([parentProductId])
  @@map("product_components")
}

// ============================================================
// SITE SETTINGS (key-value store for admin-configurable options)
// ============================================================

model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("site_settings")
}

// ============================================================
// AUDIT LOG (admin actions)
// ============================================================
// Tracking aller Admin-Schreib-Aktionen außerhalb des bestehenden
// OrderEvent-Logs. Pattern: jeder admin-API-Endpoint, der State
// ändert (POST/PATCH/DELETE auf /api/admin/**), schreibt eine Zeile
// via writeAuditLog() in @/lib/admin-audit. Compliance + Forensik.
// AUDIT_REPORT_v3 §4.14.

model AdminAuditLog {
  id         String   @id @default(cuid())
  // User der die Aktion ausgeführt hat. Nullable falls der User später
  // gelöscht wird — Log soll Audit-bar bleiben.
  actorId    String?
  // Snapshot des Actor-Emails zum Zeitpunkt der Aktion. Bleibt erhalten
  // auch wenn User später gelöscht/anonymisiert wird.
  actorEmail String?
  // Verb: "create", "update", "delete", "refund", "publish", etc.
  // Free-form String — Helper kapselt die Standard-Verben pro Resource.
  action     String
  // Dotted resource path: "order", "product", "blog_post", "promo".
  entity     String
  // ID der betroffenen Entity (z.B. Order.id).
  entityId   String
  // Optional: relevante Felder vor + nach der Änderung. JSON struktur
  // ist absichtlich locker — pro Action-Type kann der Aufrufer eigene
  // Shape mitgeben.
  payload    Json?
  // Optional: User-Agent + IP für IT-Audit. Kann null sein wenn die
  // Action aus einem Cron oder Server-Script kommt.
  userAgent  String?
  ipAddress  String?
  createdAt  DateTime @default(now())

  // Zeitstempel-Index für "letzte 100 Admin-Aktionen"-Listing.
  @@index([createdAt(sort: Desc)])
  // Pro-Entity-Filter für "wer hat was an Order X gemacht".
  @@index([entity, entityId, createdAt(sort: Desc)])
  // Pro-Actor-Filter für "was hat User X gemacht".
  @@index([actorId, createdAt(sort: Desc)])
  @@map("admin_audit_logs")
}

// ============================================================
// CONTENT (BLOG / FAQ / GLOSSAR)
// ============================================================
// Wissensbereich `/wissen` — Pillar-Pages, FAQ-CMS und Glossar.
// Vollständig denormalisiert: Author-Felder als Strings am BlogPost,
// Glossar/Post-Cross-References als String[]-Arrays mit Slugs (kein
// FK), damit Inhalte ohne Foreign-Key-Friktion gepflegt werden können.

// Author für Blog-Posts. Eigenes Modell statt denormalisierte Strings,
// damit Bio/Avatar/ORCID einmal gepflegt + von mehreren Posts genutzt
// werden. Kein FK auf User — Autoren können externe Berater oder
// Pseudonyme sein und brauchen kein Login-Konto.
model Author {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  title     String?
  bio       String?  @db.Text
  avatar    String?
  orcid     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  posts BlogPost[]

  @@map("authors")
}

model BlogCategory {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?  @db.Text
  // Manuelle Sortierreihenfolge auf Hub + Kategorie-Bar.
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  posts BlogPost[]

  @@index([sortOrder])
  @@map("blog_categories")
}

model BlogPost {
  id             String  @id @default(cuid())
  slug           String  @unique
  title          String
  // Italic-Highlight für Fraunces-Akzent im Title — Substring im
  // Title, der im Frontend als <em class="font-serif italic"> gerendert
  // wird (z.B. titleEmphasis="wie wir Peptide" → "HPLC: <em>wie wir
  // Peptide</em> auf 98 %+"). Optional; wenn null, kein Highlight.
  titleEmphasis  String?
  excerpt        String  @db.Text
  // Markdown-Body. Wird per react-markdown + remark-gfm gerendert,
  // GitHub-Alerts (`> [!NOTE]`) werden auf Callout-Komponente gemappt.
  contentMdx     String  @db.Text
  coverImage     String?
  readingMinutes Int     @default(5)

  // Author — FK auf Author-Tabelle. Bio/Avatar/ORCID werden in der
  // Admin-UI einmal pro Author gepflegt und automatisch in alle Posts
  // dieses Autors übernommen.
  authorId String
  author   Author @relation(fields: [authorId], references: [id])

  categoryId String
  category   BlogCategory @relation(fields: [categoryId], references: [id])

  // Soft-Refs zu anderen Inhalten via Slug — keine FK, weil Cross-Modell
  // (Glossar) und für Content-Migrations resilient bleibt.
  tags                String[] @default([])
  relatedGlossarSlugs String[] @default([])

  // Optionaler Slug eines Produkts, dessen aktuelle COA im
  // Article-Body als <BatchInfoCard> eingebettet wird (z.B.
  // "tirzepatide" beim HPLC-Methodik-Artikel). Kein FK weil Posts
  // ggf. auf nicht (mehr) existierende Produkte verweisen können.
  featuredBatchProductSlug String?

  seoTitle       String?
  seoDescription String? @db.Text

  // Drafts haben publishedAt = null und tauchen nicht im Hub/Sitemap auf.
  // updatedManually überschreibt updatedAt für die Anzeige
  // ("Aktualisiert am") — sinnvoll wenn z.B. nur SEO-Felder geändert
  // wurden und der Content selbst stehen bleibt.
  publishedAt     DateTime?
  updatedManually DateTime?
  // View-Tracking: client-side <BlogPostViewTracker> ruft beim Mount
  // POST /api/wissen/posts/[slug]/view, der Endpoint inkrementiert
  // dieses Feld. Anti-Bot via Redis-Lock (1 View/IP/Slug/Tag).
  // Powering "Meistgelesen"-Sortierung. AUDIT_REPORT_v3 §3.4.
  viewCount       Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Hot-Path-Sort: Hub holt latest 6 Posts, jede Kategorie-Page
  // sortiert ebenfalls nach publishedAt desc. Compound-Index für
  // Kategorie+Date deckt beide Wege.
  @@index([publishedAt(sort: Desc)])
  @@index([categoryId, publishedAt(sort: Desc)])
  @@index([authorId])
  // "Meistgelesen"-Sortierung pro Kategorie: WHERE publishedAt IS NOT
  // NULL AND categoryId = ? ORDER BY viewCount DESC. Compound-Index
  // damit Postgres den Sort aus dem Index lesen kann.
  @@index([categoryId, viewCount(sort: Desc)])
  @@map("blog_posts")
}

model FAQCategory {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items FAQItem[]

  @@index([sortOrder])
  @@map("faq_categories")
}

model FAQItem {
  id          String      @id @default(cuid())
  question    String      @db.Text
  answer      String      @db.Text
  categoryId  String
  category    FAQCategory @relation(fields: [categoryId], references: [id])
  sortOrder   Int         @default(0)
  isPublished Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Render-Order auf der FAQ-Seite ist (categoryId, sortOrder).
  @@index([categoryId, sortOrder])
  @@map("faq_items")
}

model GlossarTerm {
  id      String  @id @default(cuid())
  slug    String  @unique
  term    String
  // Optionales Akronym (z.B. "HPLC" hat acronym null, aber
  // "Hochleistungs-Flüssigchromatographie" hat acronym "HPLC").
  acronym String?

  shortDef         String   @db.Text
  longDef          String?  @db.Text
  relatedPostSlugs String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Glossar-Suche/-Sort nach term — index für ORDER BY term ASC.
  @@index([term])
  @@map("glossar_terms")
}
